# Copy this file to .env and adjust values before running docker compose.

# HTTP port exposed on the host
NUC_HTTP_PORT=8080

# Bearer token protecting the /mcp endpoint (leave empty to disable auth)
NUC_HTTP_BEARER_TOKEN=

# Allowed CORS origins, comma-separated. Use * to allow all.
NUC_ALLOWED_ORIGINS=*

# --- Chart source (uncomment one block) ---

# Option A: clone from GitHub (default — no changes needed)
NUC_ROOT_CHART_GIT_URL=https://github.com/nixys/nxs-universal-chart.git
NUC_ROOT_CHART_GIT_REF=v3.1.0

# Option B: local directory mount
# Uncomment the volume line in docker-compose.yaml and set:
# NUC_ROOT_CHART_DIR=/tmp/nxs-universal-chart

# Option C: OCI registry pull
# NUC_ROOT_CHART_OCI_REF=oci://registry.nixys.ru/nuc/nxs-universal-chart
# NUC_ROOT_CHART_OCI_VERSION=3.1.0
